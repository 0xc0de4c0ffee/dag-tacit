# Bitcoin RPC URL for fetching blocks
# Get a free key from https://drpc.org or use your own Bitcoin node
BITCOIN_RPC_URL="https://lb.drpc.live/bitcoin/YOUR_KEY_HERE"

# Network (mainnet or signet)
BITCOIN_NETWORK="mainnet"

# Starting height for Tacit genesis (mainnet: 948242)
START_HEIGHT="948242"

# IPFS API endpoint for CAR import (defaults to local Kubo)
IPFS_API_URL="http://127.0.0.1:5001"

# IPFS Gateway URL for root link display (defaults to local gateway)
IPFS_GATEWAY_URL="http://127.0.0.1:8080"
